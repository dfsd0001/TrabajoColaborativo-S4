# outputs/models/*.pkl  # Descomentar si los modelos son > 100MB

# --- IDEs ---
.vscode/settings.json
.idea/
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Logs y temporales ---
*.log
*.tmp
*.temp
